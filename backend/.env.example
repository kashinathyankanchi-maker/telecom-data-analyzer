# Copy this file to .env and fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/telecom_analyzer

# API settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated list of allowed origins (Flutter web / desktop dev server)
ALLOWED_ORIGINS=http://localhost,http://localhost:8080

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate a strong secret with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_KEY

# Token algorithm — HS256 is standard for symmetric signing
JWT_ALGORITHM=HS256

# Access token expiry in minutes (default 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin user created on first startup (change after first login!)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@telecom.local
ADMIN_PASSWORD=Admin@1234!
